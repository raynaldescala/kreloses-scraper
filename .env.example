# Kreloses Credentials (required)
KRELOSES_EMAIL=your_email@example.com
KRELOSES_PASSWORD=your_password

# Default password hash for imported customers (required)
DEFAULT_PASSWORD_HASH=your_bcrypt_hash_here

# URLs (optional - defaults shown)
# KRELOSES_LOGIN_URL=https://www.kreloses.com/account/login
# KRELOSES_CUSTOMER_LIST_URL=https://sea.kreloses.com/Customer/List

# Output files (optional - defaults shown)
# PETS_OUTPUT_FILE=pets.csv
# CUSTOMERS_OUTPUT_FILE=customers.csv
# PROGRESS_FILE=scraper_progress.txt

# Starting customer ID (optional - default: 100)
# CUSTOMER_ID_START=100